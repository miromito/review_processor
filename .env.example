# Локально без Docker: свой URI (часто без авторизации).
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=review_analytics

# Docker Compose: логин и пароль root для Mongo (обязательно задать в .env рядом с compose).
# Пользователь создаётся только при первом запуске с пустым томом mongo_data.
# Если том уже был без auth — сделайте бэкап, удалите том и поднимите стек заново.
MONGO_INITDB_ROOT_USERNAME=review_app
MONGO_INITDB_ROOT_PASSWORD=change_me_strong_password
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano
TOKEN_LIMIT_T=100000
ANALYSIS_BATCH_TOKEN_BUDGET=50000
MAX_UPLOAD_MB=15
# Google Sheets (import по ссылке + фоновый опрос). Таймаут и лимит тела ответа CSV.
# SHEET_FETCH_TIMEOUT_S=45
# SHEET_MAX_BYTES=20971520

# JWT-вход: непустой AUTH_USERNAME + JWT_SECRET — нужны оба. Без логина приложение ведёт себя как раньше.
# Секрет — 64 hex-символа (32 байта), например: openssl rand -hex 32
# AUTH_USERNAME=admin
# AUTH_PASSWORD=смените_пароль
# JWT_SECRET=
# JWT_EXPIRE_MINUTES=10080
# COOKIE_SECURE=false

# Почта: уведомления о завершении анализа и важные уведомления по проекту. Если SMTP_HOST пуст, письма не отправляются.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_USE_SSL=false
# SMTP_USE_STARTTLS=true
# MAIL_FROM=noreply@example.com
# APP_BASE_URL=http://localhost:8000

# Версия в подвале (опционально). В Docker обычно задаётся при сборке: APP_VERSION=$(git rev-parse --short HEAD) docker compose build
# APP_VERSION=abc1234
